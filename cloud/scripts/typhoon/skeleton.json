  "mechanics": [
    {
      "id": "timeline_puzzle",
      "act": "act3",
      "params": {
        "slots": 6,
        "slotLabels": [
          "23:12",
          "23:20",
          "23:28",
          "23:31",
          "23:44",
          "23:50"
        ],
        "fragments": [
          {
            "character": "P3",
            "slot": 0,
            "label": "老板打电话来，说无论如何不许开闸——开了进水淹了货，你赔得起吗。我说：好。"
          },
          {
            "character": "P1",
            "slot": 1,
            "label": "我在对面组屋楼下躲雨。水已经到膝盖，整条街的灯灭了两盏，看不清对面。"
          },
          {
            "character": "P2",
            "slot": 2,
            "label": "姐姐打给我，说她被困在一间五金店门口，叫我别担心，她马上进去躲。"
          },
          {
            "character": "P3",
            "slot": 3,
            "label": "有人在敲闸门。敲得很急，后来变成拍，拍得整块铁皮都在响。我站在里面，离门两步。我没动。"
          },
          {
            "character": "P1",
            "slot": 4,
            "label": "我看见闸门底下伸出来一双手。我喊了一声，没人应。我打了999。"
          },
          {
            "character": "P2",
            "slot": 5,
            "label": "电话断了。她最后一句话是——他们不开门。"
          }
        ],
        "hints": [
          {
            "afterAttempts": 3,
            "narrationKey": "nar.act3.assist1"
          },
          {
            "afterMin": 14,
            "narrationKey": "nar.act3.assist2",
            "effect": "lock_one_correct"
          }
        ]
      }
    }
