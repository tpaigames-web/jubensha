  "mechanics": [
    {
      "id": "timeline_puzzle",
      "act": "act3",
      "params": {
        "slots": 4,
        "slotLabels": [
          "一星期前·夜",
          "周三·晚 9 点",
          "周三·深夜 11 点",
          "周四·清晨 6:10"
        ],
        "fragments": [
          {
            "character": "P3",
            "slot": 0,
            "label": "他从神龛底下摸出铁盒，把最后的钱数给我，手抖了一下，笑着说「这次是最后一次咯」。我走的时候回头看，他在妈的照片前站了很久，嘴巴一直在动。"
          },
          {
            "character": "P2",
            "slot": 1,
            "label": "他打电话给我，只说了一句：「这个星期六你回来一趟好不好。」我说月底太忙，下个月吧。他停了两秒，说「好」，就挂了。他从来没主动叫我回来过。"
          },
          {
            "character": "P1",
            "slot": 2,
            "label": "我起夜下楼倒水，看见柜台那盏灯还亮着。他一个人坐在后面，摊着一张纸看。我以为他在算账，就上楼睡了。那是我最后一次看见他坐着。"
          },
          {
            "character": "P4",
            "slot": 3,
            "label": "我照常六点十分来开门，门是从里面反锁的——三十年来第一次。我敲了很久没人应，最后用自己那把钥匙开的门。他伏在柜台上，手里还攥着粉笔。"
          }
        ],
        "hints": [
          {
            "afterAttempts": 3,
            "narrationKey": "nar.act3.assist1"
          },
          {
            "afterMin": 20,
            "narrationKey": "nar.act3.assist2",
            "effect": "lock_one_correct"
          }
        ]
      }
    }
